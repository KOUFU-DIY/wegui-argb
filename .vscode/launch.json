{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Simulator: Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Simulator/build/wegui_sim.exe",
            "cwd": "${workspaceFolder}/Simulator/build",
            "MIMode": "gdb",
            "miDebuggerPath": "D:/msys64/mingw64/bin/gdb.exe",
            "preLaunchTask": "sim: build",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "externalConsole": false
        }
    ]
}
