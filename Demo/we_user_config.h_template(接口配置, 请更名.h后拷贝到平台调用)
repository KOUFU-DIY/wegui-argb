#ifndef WE_USER_CONFIG_H
#define WE_USER_CONFIG_H

/* 请拷贝到对应平台里包含调用 */

#define DEEP_RGB565 (4) /* RGB565 */
#define DEEP_RGB888 (5) /* RGB888 */
/* -------------------------- 屏幕设置 -------------------------- */
/* 设置屏幕宽类型 */
#define LCD_DEEP (DEEP_RGB565)

/* 设置屏幕宽高 */
#define SCREEN_WIDTH (240)
#define SCREEN_HEIGHT (280)

/* 设置屏幕显存 
 * 最小设置1行*/
#define GRAM_NUM (SCREEN_WIDTH * 1)

/* DMA双BUF模式开关 */
#define GRAM_DMA_BUFF_EN (0)

/* ------------------------- 脏矩形配置 ------------------------- */
/* 设置脏矩形策略
 * 0: 全屏脏矩形
 * 1: 最小包围盒矩形
 * 2: 智能合并脏矩形*/
#define WE_CFG_DIRTY_STRATEGY (2)

/* 当脏矩形策略为2时,设置脏矩形数量上限,
 * 推荐取4~8 */
#define WE_CFG_DIRTY_MAX_NUM (8)

/* 脏矩形调试开关
 * 0: 关闭
 * 1: 打开,脏区将用红框标记*/
#define WE_CFG_DEBUG_DIRTY_RECT (0)

/* ------------------------- 功能裁剪开关 ------------------------- */
/* 1: 保留索引 QOI 解码
 * 0: 裁掉索引 QOI 相关绘图函数和图片控件分发路径 */
#define WE_CFG_ENABLE_INDEXED_QOI (1)

/* ------------------------- GUI 周期任务配置 ------------------------- */
/* 设置GUI任务队列数量上限数量
 * 说明:内置运动的控件注册时将会占用一个槽位 
 * 容器控件: 占用1槽位, 有自动吸附动画功能*/
#define WE_CFG_GUI_TASK_MAX_NUM (4)

/* -------------------------- 输入接口 -------------------------- */
/* 输入接口(按键或触摸)开关
 * 0: 关闭, 节省空间
   1: 打开输入接口*/
#define WE_CFG_ENABLE_INPUT_PORT_BIND (0)

/* ------------------------ 外部储存接口 ------------------------ */
/* 外部储存接口开关
 * 0: 关闭, 节省空间
   1: 打开*/
#define WE_CFG_ENABLE_STORAGE_PORT_BIND (0)


#endif
